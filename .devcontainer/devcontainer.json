{
    "name": "Advanced Fluid Analysis (Julia 1.10 LTS)",
    // バージョン 1.10 を直接指定した公式イメージを使用
    "image": "julia:1.10-bookworm",

    "remoteEnv": {
        "JULIA_CPU_TARGET": "generic;sandybridge,-xsaveopt,zkn"
    },

    "customizations": {
        "vscode": {
            "extensions": [
                "julialang.language-julia",
                "ms-toolsai.jupyter"
            ]
        }
    },

    // 起動後に必要なものをインストール
    // コンテナ内でJupyterを動かすために「IJulia」を明示的に追加します
    "postCreateCommand": "julia -e 'using Pkg; Pkg.add([\"IJulia\", \"Plots\", \"CairoMakie\", \"Printf\", \"Interact\"])'"
}
